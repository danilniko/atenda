# Copiar para .env.prod e preencher — usado pelo docker-compose.prod.yml

# MongoDB (usado pela app e para criar o utilizador root do container mongodb)
MONGO_INITDB_ROOT_USERNAME=atenda
MONGO_INITDB_ROOT_PASSWORD=troque-esta-password
MONGODB_DB=atenda
MONGODB_URI=mongodb://atenda:troque-esta-password@mongodb:27017/atenda?authSource=admin

# App
NEXT_PUBLIC_SITE_URL=https://atenda.pt
NEXT_PUBLIC_META_PIXEL_ID=
