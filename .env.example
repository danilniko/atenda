# MongoDB — obrigatório para guardar leads
# MongoDB Atlas (gratuito): https://www.mongodb.com/atlas → Create cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=atenda

# Meta Pixel — opcional
NEXT_PUBLIC_META_PIXEL_ID=

# URL pública do site (para sitemap/canonical)
NEXT_PUBLIC_SITE_URL=https://atenda.pt
